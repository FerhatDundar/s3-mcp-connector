      "command": "${CLAUDE_PLUGIN_ROOT}/servers/go/s3-connector-server",
      "env": {
        "AWS_REGION": "us-east-1",
        "AWS_ACCESS_KEY_ID": "PASTE_YOUR_AWS_ACCESS_KEY_ID_HERE",
